# FitNova Sales Call Intelligence System Configuration

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitnova

# Gemini AI API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=1024

# Storage Paths
UPLOAD_FOLDER=./storage/audio
TRANSCRIPT_FOLDER=./storage/transcripts
CONVERSATION_FOLDER=./storage/conversations
ANALYSIS_FOLDER=./storage/analysis

# Logging Config
LOG_LEVEL=INFO

# Faster Whisper Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Pyannote Speaker Diarization Configuration
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
PYANNOTE_AUTH_TOKEN=your_huggingface_auth_token_here
PYANNOTE_DEVICE=cpu
